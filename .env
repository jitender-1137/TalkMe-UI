# Server-side API URL (Backend IP is completely hidden from client-side code)
API_URL=http://localhost:8080/api/v1

# Giphy API key used for the in-app GIF picker (client-side, public by nature)
NEXT_PUBLIC_GIPHY_API_KEY=sXpGFDGZs0Dv1mmNFvYaGUvYwKX0PWIh

# CloudFlare Site key for Captcha
#NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADosWHn7ubq_Fjcu

# --- SEO ---
# Canonical public origin (no trailing slash). Used for canonical tags, sitemap,
# robots, and Open Graph URLs. Baked in at build time.
NEXT_PUBLIC_SITE_URL=https://talkme.fun

# Google Search Console verification token (HTML-tag method).
# Build-time only: the token is inlined into the exported HTML, so you MUST
# rebuild the JAR after setting it. Paste the value from Search Console's
# "HTML tag" method (the content="..." part) and uncomment:
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=BgM_9XjPk97ERfbo0_SewJ0Y2_DOM8BD02mN2lqqlEw