# Server-side API URL (Backend IP is completely hidden from client-side code)
#Example: http://92.4.85.168:8080/api/v1
API_URL=http://localhost:8080/api/v1

# Giphy API key used for the in-app GIF picker (exposed client-side).
# Get one at https://developers.giphy.com/. Falls back to Giphy's rate-limited
# public beta key if unset.
NEXT_PUBLIC_GIPHY_API_KEY=

# --- SEO ---
# Canonical public origin (no trailing slash). Drives sitemap, robots, canonical
# tags, and Open Graph URLs. MUST be set in production.
NEXT_PUBLIC_SITE_URL=https://talkme.fun

# Google Search Console verification token (Settings → Ownership → HTML tag).
# Paste only the token value, not the full meta tag. Optional until you verify.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
